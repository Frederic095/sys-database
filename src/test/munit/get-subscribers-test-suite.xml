<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit" xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">
	<munit:config name="get-subscribers-test-suite.xml" />
	<munit:test name="get-subscribers-test-suiteTest" doc:id="86eb59a0-314f-40e8-aaab-f7e1ad2ac6a9" >
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock when" doc:id="528c7d65-e6b6-4b42-b515-008873ddffce" processor="db:select">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Select" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="be8812f5-6899-4024-91b7-a84680bf99c1" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:payload value='#[readUrl("classpath://data/Subscribers.json","application/json")]' />
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:spy doc:name="Subscribers to SDM" doc:id="89d75fea-56a4-4fd7-aac5-288f794ece1b" processor="ee:transform">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Suscribers to SDM" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="415e7a7c-b81f-446c-8243-60a5ee99dc11" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:after-call >
					<munit-tools:assert-equals doc:name="Assert equals" doc:id="9dcc74b5-dace-48a7-a46a-2d1e752a8420" actual="#[payload]" expected='#[readUrl("classpath://data/SDM[].json","application/json")]'/>
				</munit-tools:after-call>
			</munit-tools:spy>
		</munit:behavior>
		<munit:execution >
			<flow-ref doc:name="to impl-get-subscribers" doc:id="cb3c6cd5-8630-49ce-af5d-a9d0e43fccbf" name="impl-get-subscribers"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:verify-call doc:name="Verify call" doc:id="c257a246-a599-4a02-a3fa-4946c918a0a3" processor="logger" atLeast="1">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="DEBUG" attributeName="level" />
					<munit-tools:with-attribute whereValue="End" attributeName="doc:name" />
					<munit-tools:with-attribute whereValue="b3560d30-81da-49d6-a4c2-f1b6d7153804" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:verify-call>
		</munit:validation>
	</munit:test>


</mule>
